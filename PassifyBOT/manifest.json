{
  "manifest_version": 3,
  "name": "Passify - Motor de Automação Blip",
  "version": "1.0",
  "description": "Automação de triagem corrigida para disparar filtros nativos no Blip",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.blip.ai/*"],
      "js": [
        "firebase-app-compat.js",
        "firebase-database-compat.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {}
}
